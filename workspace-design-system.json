          "background": "#ffffff",
          "borderRadius": "50%",
          "transition": "transform 150ms ease"
        },
        "checked": {
          "trackBackground": "#7c3aed",
          "thumbTransform": "translateX(18px)"
        }
      },
      
      "checkbox": {
        "size": "16px",
