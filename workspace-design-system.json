        "usage": {
          "rules": [
            "Chakra colors are ACCENTS only - never background or primary text colors",
            "Use for: borders, icon colors, small badges, subtle glows, animations",
            "Crown chakra violet (#9333ea) is the primary accent for the entire system",
            "Other chakra colors used contextually based on meaning",
            "Always ensure sufficient contrast against dark backgrounds",
            "Use 'glow' variants for subtle animations and hover effects"
          ],
          "examples": {
            "borderAccent": "border-left: 2px solid #9333ea",
            "iconColor": "color: #22c55e (for success/heart)",
            "badgeGlow": "box-shadow: 0 0 8px rgba(147, 51, 234, 0.3)",
            "pulseAnimation": "Use chakra glow colors for subtle pulsing effects"
          }
        }
