{
  "designSystem": {
    "metadata": {
      "name": "Workspace Platform Design System",
      "version": "1.1.0",
      "description": "A Cursor IDE-inspired design system for the workspace platform web interface, incorporating the Seven Chakras color system as accents. The crown chakra violet serves as the primary accent, with other chakra colors used contextually.",
      "lastUpdated": "2025-12-04",
      "aiAgentContext": "This design system mirrors Cursor IDE aesthetics - dark theme, minimal UI, clean lines, and subtle interactions. Chakra colors are used as meaningful accents: Crown (primary), Third Eye (strategy), Throat (communication), Heart (success/health), Solar Plexus (action), Sacral (creativity), Root (foundation/alerts).",
      "symbolism": {
        "treeOfLife": "The Architect's profile image represents the Tree of Life (Celtic: Crann Bethadh) - symbolizing interconnection, balance, renewal, protection, strength, durability, knowledge, experience, and wisdom. The tree's roots (foundation), trunk (stability), and branches (growth) mirror our ecosystem structure.",
        "chakraSystem": "The seven chakra colors align with our organizational energy centers, bringing ancient wisdom into modern design."
      },
      "mockupStatus": {
        "location": "/var/www/dashboard/angels-hub/pages/ui/",
        "status": "Active mockup for future app redesign",
        "liveUrl": "https://angelshub.app/pages/ui/",
        "note": "This UI mockup will serve as the foundation for the full workspace platform application."
      }
    },
    
