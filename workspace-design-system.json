        }
      },
      "container": {
        "maxWidth": "1200px",
        "padding": "0 24px",
        "margin": "0 auto"
      }
    },
    
    "iconography": {
      "sizes": {
        "xs": "12px",
        "sm": "14px",
        "md": "16px",
        "lg": "20px",
        "xl": "24px"
      },
      "strokeWidth": "1.5px",
      "color": "currentColor"
    },
    
    "aiAgentRules": {
      "designPrinciples": [
        "Maintain Cursor IDE's dark, minimal aesthetic with high information density",
        "Use Crown Chakra violet (#9333ea) as the primary accent for focus states, active items, and CTAs",
        "Use other chakra colors as contextual accents (borders, icons, badges) based on their meaning",
        "Preserve generous but efficient whitespace - not wasteful, but breathable",
        "Ensure all interactive elements have subtle but clear hover/focus states",
        "Use 150ms transitions for micro-interactions, 200-300ms for larger animations",
        "Typography should be clean and readable - Inter for UI, JetBrains Mono for code",
        "Borders should be subtle (#1f1f1f to #2a2a2a range)",
        "Shadows are used minimally - mainly for floating elements like dropdowns and modals",
        "Interface should feel like a natural extension of Cursor IDE when embedded"
      ],
      
      "componentGeneration": {
        "buttons": {
          "rules": [
            "Primary buttons are violet - use only for main actions",
            "Secondary buttons have subtle borders and hover states",
            "Ghost buttons are for less important actions",
            "Icon-only buttons should have 28x28px size minimum for touch targets",
            "All buttons should have focus rings using box-shadow, not outline"
          ]
        },
        "forms": {
          "rules": [
            "Inputs have dark backgrounds (#1a1a1a) with subtle borders",
            "Focus states use violet color with subtle glow",
            "Error states use red (#ef4444) with appropriate messaging",
            "Labels are above inputs, not inline",
            "Maintain 32px height for standard inputs"
          ]
        },
        "navigation": {
          "rules": [
            "Sidebar is fixed with tree-view structure",
            "Active items have violet accent (left border or background)",
            "Hover states are subtle (rgba white overlay)",
            "Section headers are uppercase, muted color",
            "Collapsible sections with chevron icons"
          ]
        },
        "dataDisplay": {
          "rules": [
            "Tables have sticky headers with subtle background",
            "Row hover states are very subtle",
            "Use badges for status indicators",
            "Code blocks have darker background than panels",
            "Maintain monospace font for any code or technical data"
          ]
        }
      },
      
      "accessibilityRequirements": [
        "All interactive elements must be keyboard navigable",
        "Focus indicators must be visible (violet box-shadow)",
        "Color contrast meets WCAG AA standards",
        "Don't rely on color alone - use icons and text for status",
        "All images and icons have alt text or aria-labels",
        "Modals trap focus and return focus on close",
        "Skip links for keyboard navigation"
      ],
      
      "performanceGuidelines": [
        "Use CSS transitions instead of JavaScript animations where possible",
        "Lazy load images and heavy components",
        "Virtual scroll for long lists",
        "Debounce search inputs",
        "Skeleton loaders for async content",
        "Minimize layout shifts during loading"
      ],
      
      "responsiveBreakpoints": {
        "sm": "640px",
        "md": "768px",
        "lg": "1024px",
        "xl": "1280px",
        "2xl": "1536px"
      },
      
      "stateManagement": {
        "loading": [
          "Use skeleton loaders for content areas",
          "Spinner for button loading states",
          "Disable interactions during async operations",
          "Show progress for multi-step operations"
        ],
        "error": [
          "Display inline errors below form fields",
          "Use toast notifications for global errors",
          "Provide clear, actionable error messages",
          "Red color with appropriate backgrounds"
        ],
        "empty": [
          "Show meaningful empty states with guidance",
          "Use muted text and optional icons",
          "Provide primary action to resolve empty state"
        ],
        "success": [
          "Brief toast notifications for success",
          "Green accent for success states",
          "Auto-dismiss after 3-5 seconds"
        ]
      }
    },
    
    "cursorIntegration": {
      "notes": "This design system is optimized for use within Cursor IDE's embedded browser",
      "considerations": [
        "Match Cursor's existing color palette for seamless integration",
        "Use similar interaction patterns (command palette, tree views)",
        "Maintain similar typography scales",
        "Support for reduced motion preferences",
        "Dark theme only - no light mode toggle needed"
      ],
      "embeddedBrowserOptimizations": [
        "Compact UI to maximize content area",
        "Avoid full-page scrolling when possible",
        "Use panels and split views like IDE",
        "Command palette pattern for quick navigation",
        "Keyboard shortcuts for power users"
      ]
    }
  }
