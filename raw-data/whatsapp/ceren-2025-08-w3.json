  {
    "id": "ceren-2025-08-w3-c6",
    "start_time": "20.08.2025, 07:17:33",
    "end_time": "20.08.2025, 08:32:10",
    "message_count": 56,
    "messages": [
      {
        "timestamp": "20.08.2025, 07:17:33",
        "from": "Ceren",
        "message": "Aşkım hocayla 9dan sonra gelir dediler"
      },
      {
        "timestamp": "20.08.2025, 07:18:05",
        "from": "Bora",
        "message": "Teşekkür ederim bebek"
      },
      {
        "timestamp": "20.08.2025, 07:18:17",
        "from": "Bora",
        "message": "Ne kadar sonra acaba?"
      },
      {
        "timestamp": "20.08.2025, 07:18:45",
        "from": "Bora",
        "message": "Biz muhtemelen çeyrek kala falan çıkarız. Zaten 20 dk falan sürüyor"
      },
      {
        "timestamp": "20.08.2025, 07:18:54",
        "from": "Bora",
        "message": "9 civarı oradayız yani"
      },
      {
        "timestamp": "20.08.2025, 07:19:14",
        "from": "Bora",
        "message": "Babam uykusunu alamamış o yüzden biraz ağır davranıyor"
      },
      {
        "timestamp": "20.08.2025, 07:42:02",
        "from": "Bora",
        "message": "Babam rapor çıktı mı diye sordu, ben de çıktı, farklı bir şey demedi dedim"
      },
      {
        "timestamp": "20.08.2025, 07:42:24",
        "from": "Ceren",
        "message": "Tamam canım"
      },
      {
        "timestamp": "20.08.2025, 07:42:45",
        "from": "Bora",
        "message": "Üzüldü tabi duyunca"
      },
      {
        "timestamp": "20.08.2025, 07:43:27",
        "from": "Bora",
        "message": "Senin de aklında bulunsun, patoloji raporunu bugün almayalım bebek, sonra biz gider alırız"
      },
      {
        "timestamp": "20.08.2025, 07:43:46",
        "from": "Bora",
        "message": "Şimdi bakmak ister annem onlara"
      },
      {
        "timestamp": "20.08.2025, 07:44:17",
        "from": "Ceren",
        "message": "Tamam canım"
      },
      {
        "timestamp": "20.08.2025, 07:44:25",
        "from": "Bora",
        "message": "Biz yarın gelip alcaz, önce bir seni eve götürelim falan deriz"
      },
      {
        "timestamp": "20.08.2025, 07:44:26",
        "from": "Ceren",
        "message": "Annemle sohbet ediyoruz"
      },
      {
        "timestamp": "20.08.2025, 07:44:30",
        "from": "Ceren",
        "message": "Yazamıyorum"
      },
      {
        "timestamp": "20.08.2025, 07:44:35",
        "from": "Bora",
        "message": "Selam söyle"
      },
      {
        "timestamp": "20.08.2025, 08:04:04",
        "from": "Ceren",
        "message": "Doktor geldi"
      },
      {
        "timestamp": "20.08.2025, 08:04:14",
        "from": "Ceren",
        "message": "Şu anda burada"
      },
      {
        "timestamp": "20.08.2025, 08:08:17",
        "from": "Ceren",
        "message": "Sorun yok"
      },
      {
        "timestamp": "20.08.2025, 08:08:32",
        "from": "Ceren",
        "message": "Bugün çıkabilirsin dedi"
      },
      {
        "timestamp": "20.08.2025, 08:08:43",
        "from": "Bora",
        "message": "Arayım mı?"
      },
      {
        "timestamp": "20.08.2025, 08:08:44",
        "from": "Ceren",
        "message": "Bir daha geldiler"
      },
      {
        "timestamp": "20.08.2025, 08:09:13",
        "from": "Ceren",
        "message": "Boyundakini çıkarıyorlar şimdi"
      },
      {
        "timestamp": "20.08.2025, 08:09:19",
        "from": "Ceren",
        "message": "Daha bilgi vermediler"
      },
      {
        "timestamp": "20.08.2025, 08:09:23",
        "from": "Ceren",
        "message": "Neredesiniz?"
      },
      {
        "timestamp": "20.08.2025, 08:09:39",
        "from": "Bora",
        "message": "Geliyoruz"
      },
      {
        "timestamp": "20.08.2025, 08:09:52",
        "from": "Bora",
        "message": "Adam yorgun, çıkamadık"
      },
      {
        "timestamp": "20.08.2025, 08:10:14",
        "from": "Ceren",
        "message": "Daha çıkmadınız mı?"
      },
      {
        "timestamp": "20.08.2025, 08:10:31",
        "from": "Bora",
        "message": "Çıkamadık aşkım"
      },
      {
        "timestamp": "20.08.2025, 08:10:37",
        "from": "Bora",
        "message": "Şimdi çıktık"
      },
      {
        "timestamp": "20.08.2025, 08:10:58",
        "from": "Bora",
        "message": "Beklemelerini söyler misin bir tanem 15-20 dk"
      },
      {
        "timestamp": "20.08.2025, 08:10:59",
        "from": "Ceren",
        "message": "Sorular varsa yaz canım"
      },
      {
        "timestamp": "20.08.2025, 08:11:15",
        "from": "Ceren",
        "message": "Yani onların programı var"
      },
      {
        "timestamp": "20.08.2025, 08:11:18",
        "from": "Ceren",
        "message": "Biliyorsun"
      },
      {
        "timestamp": "20.08.2025, 08:11:21",
        "from": "Ceren",
        "message": "Söylwrim"
      },
      {
        "timestamp": "20.08.2025, 08:11:25",
        "from": "Ceren",
        "message": "Neyse"
      },
      {
        "timestamp": "20.08.2025, 08:11:30",
        "from": "Ceren",
        "message": "Yazamayacağım"
      },
      {
        "timestamp": "20.08.2025, 08:11:36",
        "from": "Ceren",
        "message": "Sen sorularını yaz bebek"
      },
      {
        "timestamp": "20.08.2025, 08:12:01",
        "from": "Bora",
        "message": "Özür dilerim sevgilim"
      },
      {
        "timestamp": "20.08.2025, 08:12:31",
        "from": "Ceren",
        "message": "Özir dikemene gerek yok bebek"
      },
      {
        "timestamp": "20.08.2025, 08:12:36",
        "from": "Ceren",
        "message": "Yaz sorularını"
      },
      {
        "timestamp": "20.08.2025, 08:13:18",
        "from": "Bora",
        "message": "Patoloji sonucunu nereden alacağız"
      },
      {
        "timestamp": "20.08.2025, 08:13:48",
        "from": "Bora",
        "message": "Onkoloji için isimleri tekrar alabilir miyiz? Ne soracağız ne isteyeceğiz onlardan"
      },
      {
        "timestamp": "20.08.2025, 08:15:40",
        "from": "Bora",
        "message": "Seyahat engeli kalkacak mı, ne zaman kalkacak?"
      },
      {
        "timestamp": "20.08.2025, 08:16:07",
        "from": "Bora",
        "message": "15 dkya oradayız bu arada"
      },
      {
        "timestamp": "20.08.2025, 08:17:41",
        "from": "Ceren",
        "message": "Öğlen geliyorlar bebek"
      },
      {
        "timestamp": "20.08.2025, 08:17:47",
        "from": "Ceren",
        "message": "Merak etme"
      },
      {
        "timestamp": "20.08.2025, 08:18:16",
        "from": "Bora",
        "message": "Oh tamam bebek, çok teşekkür ederim sana, seni çok seviyorum"
      },
      {
        "timestamp": "20.08.2025, 08:18:56",
        "from": "Ceren",
        "message": "Ben de seni seviyorum bızdık"
      },
      {
        "timestamp": "20.08.2025, 08:19:05",
        "from": "Ceren",
        "message": "Annem çay istedi"
      },
      {
        "timestamp": "20.08.2025, 08:19:12",
        "from": "Ceren",
        "message": "Şimdi onu almaya gidiyorum"
      },
      {
        "timestamp": "20.08.2025, 08:19:28",
        "from": "Bora",
        "message": "E getirmiyorlar mı çay?"
      },
      {
        "timestamp": "20.08.2025, 08:19:30",
        "from": "Bora",
        "message": "Bir sor"
      },
      {
        "timestamp": "20.08.2025, 08:19:39",
        "from": "Bora",
        "message": "Getiriyorlar normalde"
      },
      {
        "timestamp": "20.08.2025, 08:31:59",
        "from": "Ceren",
        "message": "Öyleymiş"
      },
      {
        "timestamp": "20.08.2025, 08:32:10",
        "from": "Ceren",
        "message": "Neyse bekletmemiş oldum"
      }
    ]
  },
  {
